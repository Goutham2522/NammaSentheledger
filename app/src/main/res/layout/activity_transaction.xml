<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5EFE9">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Customer Name -->

            <TextView
                android:id="@+id/txtCustomer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Customer"
                android:textColor="#444444"
                android:textSize="28sp"
                android:textStyle="bold"/>

            <!-- Balance -->

            <TextView
                android:id="@+id/txtBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Balance: ₹0"
                android:textColor="#FF6B00"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <!-- Amount -->

            <EditText
                android:id="@+id/etAmount"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:layout_marginTop="30dp"
                android:background="@android:drawable/edit_text"
                android:hint="Enter Amount"
                android:inputType="numberDecimal"
                android:padding="16dp"
                android:textSize="18sp"/>

            <!-- Credit Button -->

            <Button
                android:id="@+id/btnCredit"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="25dp"
                android:backgroundTint="#FF6B00"
                android:text="SAVE CREDIT"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <!-- Payment Button -->

            <Button
                android:id="@+id/btnPayment"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="18dp"
                android:backgroundTint="#4CAF50"
                android:text="SAVE PAYMENT"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <!-- History Title -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="35dp"
                android:text="Transaction History"
                android:textColor="#444444"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <!-- History -->

            <TextView
                android:id="@+id/txtHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:textColor="#444444"
                android:textSize="16sp"/>

            <!-- Delete ID -->

            <EditText
                android:id="@+id/etDelete"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:layout_marginTop="30dp"
                android:background="@android:drawable/edit_text"
                android:hint="Enter Transaction ID"
                android:inputType="number"
                android:padding="16dp"
                android:textSize="18sp"/>

            <!-- Delete Button -->

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="40dp"
                android:backgroundTint="#F44336"
                android:text="DELETE TRANSACTION"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </ScrollView>

</RelativeLayout>